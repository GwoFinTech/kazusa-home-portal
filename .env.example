# ── Domain ──
DOMAIN=home.example.com

# ── Google OAuth ──
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=***  # Must match Google Cloud Console config
GOOGLE_REDIRECT_URI=https://home.example.com/auth/callback

# ── Session ──
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=***  # e.g. .example.com (enables cross-subdomain cookies)
COOKIE_DOMAIN=...

# ── Portal ──
# Comma-separated list of hosts that bypass auth (portal domains)
PORTAL_URL=https://example.com
PORTAL_HOSTS=example.com,home.example.com

# ── Admin ──
ADMIN_EMAIL=admin@example.com

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kazusa_home
DB_USER=postgres
DB_PASSWORD=...
